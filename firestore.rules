rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticatedAs(userId) {
      return request.auth != null
        && (
          request.auth.uid == userId
          || ("uid" in request.auth.token && request.auth.token.uid == userId)
          || ("user_id" in request.auth.token && request.auth.token.user_id == userId)
          || ("sub" in request.auth.token && request.auth.token.sub == userId)
        );
    }

    // Restrict all app data to authenticated users under users/{uid}.
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticatedAs(userId);
    }

    // Deny every other path by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}