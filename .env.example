# Required when VITE_FREELANCE_DATA_ADAPTER=firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=work-tracker-98f72
VITE_FIREBASE_APP_ID=

# Optional Firebase web config fields
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Adapter selection (defaults to json when unset)
# For local dev in this repo, .env.development sets this to firebase.
# VITE_FREELANCE_DATA_ADAPTER=firebase

# Set to "true" to route Firebase traffic through local emulators (Auth: 9099, Firestore: 8080).
# VITE_USE_FIREBASE_EMULATOR=true
