{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Tag History Schema",
    "description": "Record of unique tags used in entries (for autocomplete)",
    "type": "object",
    "required": ["tag", "count", "lastUsedAt"],
    "properties": {
        "tag": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "The tag string (case-insensitive storage, but case-sensitive query for autocomplete)"
        },
        "count": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of entries using this tag"
        },
        "lastUsedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of last use"
        }
    },
    "additionalProperties": false
}
