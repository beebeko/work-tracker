{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Position History Schema",
    "description": "Record of positions used per organization (for autocomplete)",
    "type": "object",
    "required": ["organizationId", "position", "count", "lastUsedAt"],
    "properties": {
        "organizationId": {
            "type": "string",
            "pattern": "^org-[a-z0-9]+$",
            "description": "Organization this position belongs to"
        },
        "position": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Position name (Designer, Rigger, etc.)"
        },
        "count": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of entries with this position"
        },
        "lastUsedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of last use"
        }
    },
    "additionalProperties": false
}
