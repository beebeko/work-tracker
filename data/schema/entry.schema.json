{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Entry Schema",
    "description": "Work entry record in the freelance tracker",
    "type": "object",
    "required": [
        "entryId",
        "organizationId",
        "date",
        "startTime",
        "endTime",
        "venue",
        "position",
        "event",
        "tags",
        "notes",
        "createdAt",
        "updatedAt"
    ],
    "properties": {
        "entryId": {
            "type": "string",
            "pattern": "^entry-[a-z0-9]+$",
            "description": "Unique identifier for the entry (branded Id)"
        },
        "organizationId": {
            "type": "string",
            "pattern": "^org-[a-z0-9]+$",
            "description": "Org this entry is under"
        },
        "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date of work (YYYY-MM-DD)"
        },
        "startTime": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "description": "Start time (HH:MM, 24-hour)"
        },
        "endTime": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "description": "End time (HH:MM, 24-hour)"
        },
        "venue": {
            "type": "string",
            "minLength": 0,
            "maxLength": 255,
            "description": "Venue or location associated with this entry"
        },
        "position": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "Job role (Designer, Rigger, etc.)"
        },
        "rate": {
            "oneOf": [
                {
                    "type": "number",
                    "minimum": 0,
                    "description": "Hourly rate ($)"
                },
                {
                    "type": "null",
                    "description": "Rate not yet determined"
                }
            ]
        },
        "paymentMode": {
            "type": "string",
            "enum": ["hourly", "flat-fee"],
            "description": "How this shift is paid"
        },
        "flatFeeAmount": {
            "oneOf": [
                {
                    "type": "number",
                    "minimum": 0,
                    "description": "Flat fee payout for the shift"
                },
                {
                    "type": "null",
                    "description": "No flat fee set"
                }
            ]
        },
        "event": {
            "type": "string",
            "minLength": 0,
            "maxLength": 255,
            "description": "Event name (Broadway show, corporate gig, etc.)"
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50
            },
            "description": "Freeform tags (conference, QLab-trained, etc.)"
        },
        "mealPenaltyCount": {
            "type": "integer",
            "minimum": 0,
            "default": 0,
            "description": "Number of meal penalties manually recorded for this shift"
        },
        "notes": {
            "type": "string",
            "maxLength": 2000,
            "description": "Additional notes about the work"
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 creation timestamp"
        },
        "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 last update timestamp"
        }
    },
    "additionalProperties": false
}
